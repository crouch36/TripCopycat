# Supabase
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_KEY=eyJ...        # service role key — never expose to client
SUPABASE_ANON_KEY=eyJ...           # used by api/og.js (server-side)

# Google
VITE_GOOGLE_MAPS_KEY=AIza...
VITE_GEMINI_API_KEY=AIza...

# Stripe
VITE_STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_SECRET_KEY=sk_live_...

# Cloudflare R2  (add these in Vercel → Settings → Environment Variables)
R2_ACCOUNT_ID=                     # Cloudflare Account ID (32-char hex)
R2_ACCESS_KEY_ID=                  # R2 API token Access Key ID
R2_SECRET_ACCESS_KEY=              # R2 API token Secret Access Key
R2_BUCKET_NAME=tripcopycat-photos  # bucket name you created in R2
R2_PUBLIC_URL=https://photos.tripcopycat.com  # public bucket URL (r2.dev or custom domain)
